{
  "name": "open-legal-codes-server",
  "version": "0.1.0",
  "description": "Retrieve US legal codes programmatically. Give it a jurisdiction and code path, get the text back.",
  "author": "TIDY (https://tidy.com)",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "open-legal-codes": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "crawl": "tsx src/cli.ts crawl",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "mcp": "tsx src/mcp.ts",
    "web": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web"
  },
  "keywords": [
    "law",
    "legal",
    "municipal-code",
    "ordinance",
    "uslm",
    "legislation",
    "open-data",
    "government"
  ],
  "license": "MIT",
  "workspaces": [
    "web",
    "packages/cli"
  ],
  "dependencies": {
    "@browserbasehq/sdk": "^2.7.0",
    "@browserbasehq/stagehand": "^3.1.0",
    "@hono/node-server": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.0.0",
    "hono": "^4.0.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
