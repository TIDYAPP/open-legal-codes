    <section identifier="/ca-mountain-view/part-i/article-i/section-100"
             temporalId="sSection 100">
      <num>Section 100</num>
      <heading>Name</heading>
      <content>
        <p>The municipal corporation now existing and known as the City of Mountain View shall
               remain and continue a body politic and corporate in name and in fact, by the name
               of the City of Mountain View.</p>
      </content>
    </section>
  </main>
