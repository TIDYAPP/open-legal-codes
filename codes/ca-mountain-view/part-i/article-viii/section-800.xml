    <section identifier="/ca-mountain-view/part-i/article-viii/section-800"
             temporalId="sSection 800">
      <num>Section 800</num>
      <heading>Creation</heading>
      <content>
        <p>The council shall have power to provide for the creation, establishment and maintenance
               of a retirement or pension plan or plans for any or all of the appointive officers
               and employees of the city.</p>
      </content>
    </section>
