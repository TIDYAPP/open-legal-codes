    <section identifier="/ca-mountain-view/part-i/article-vi/section-605"
             temporalId="sSection 605">
      <num>Section 605</num>
      <heading>Manager pro tempore</heading>
      <content>
        <p>The city manager shall appoint, subject to the approval of the council, one of the
               other officers of the city to serve as manager pro tempore during any temporary absence
               or disability of the city manager.</p>
      </content>
    </section>
  </main>
