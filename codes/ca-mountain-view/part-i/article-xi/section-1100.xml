    <section identifier="/ca-mountain-view/part-i/article-xi/section-1100"
             temporalId="sSection 1100">
      <num>Section 1100</num>
      <heading>The fiscal year</heading>
      <content>
        <p>Unless otherwise provided by ordinance, the fiscal year of the city shall begin on
               the first day of July of each year and end on the thirtieth day of June of the following
               year.</p>
      </content>
    </section>
  </main>
