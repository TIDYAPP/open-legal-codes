  <main>
    <section identifier="/ca-mountain-view/part-i/article-v/section-508"
             temporalId="sSection 508">
      <num>Section 508</num>
      <heading>Meetings to be public</heading>
      <content>
        <p>All legislative sessions of the council, whether regular or special, shall be open
               to the public.</p>
      </content>
    </section>
