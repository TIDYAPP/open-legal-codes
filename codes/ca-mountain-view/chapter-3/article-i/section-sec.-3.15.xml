    <section identifier="/ca-mountain-view/chapter-3/article-i/section-sec.-3.15"
             temporalId="sSEC_ 3_15">
      <num>SEC. 3.15</num>
      <heading>Exceptions to chapter provisions</heading>
      <content>
        <p>The provisions of this chapter shall not be deemed to apply to the distribution of
               mail by the United States, nor to newspapers as defined in this chapter.</p>
        <p>(Ord. No. 175.481, 6/30/58.)</p>
      </content>
